@page
@model VotingSystem.Pages.candidatedashboardModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Candidate Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            background-color: #f4f6f9;
            font-family: Arial, sans-serif;
        }

        .sidebar {
            width: 230px;
            background-color: #1e3a56;
            position: fixed;
            top: 0;
            left: 0;
            height: 100%;
            display: flex;
            flex-direction: column;
            padding: 20px 0;
            color: white;
        }

            .sidebar h2 {
                text-align: center;
                font-size: 1.3rem;
                font-weight: bold;
                margin-bottom: 30px;
            }

            .sidebar a {
                color: white;
                padding: 12px 20px;
                text-decoration: none;
                display: block;
            }

                .sidebar a:hover {
                    background: #2c4a6e;
                    border-radius: 5px;
                }

        .logout-btn {
            margin-top: auto;
            padding: 12px 20px;
            background-color: #e74c3c;
            border-radius: 5px;
            text-align: center;
            font-weight: bold;
            text-decoration: none;
            color: white;
        }

            .logout-btn:hover {
                background-color: #c0392b;
            }

        .main-content {
            margin-left: 250px;
            padding: 30px;
        }

        h2 {
            font-weight: bold;
            margin-bottom: 25px;
        }

        .table thead {
            background-color: #1e3a56;
            color: white;
        }

        .status-badge {
            padding: 5px 10px;
            border-radius: 6px;
            font-size: 0.85rem;
            color: #fff;
        }

        .status-pending {
            background-color: #f39c12;
        }

        .status-active {
            background-color: #27ae60;
        }

        .status-rejected {
            background-color: #e74c3c;
        }

        img.photo-preview {
            width: 55px;
            height: 55px;
            object-fit: cover;
            border-radius: 6px;
        }
    </style>
</head>
<body>
    <div class="sidebar">
        <h2>Candidate Panel</h2>
        <a href="/CandidateDashboard">My Applications</a>
        <a href="/Logout" class="logout-btn">Logout</a>
    </div>

    <div class="main-content">
        <h2>My Applications</h2>

        <!-- ✅ Notifications -->
        @if (Model.Notifications != null && Model.Notifications.Any())
        {
            foreach (var note in Model.Notifications)
            {
                <div class="alert alert-info">@note</div>
            }
        }

        @if (Model.Applications == null || !Model.Applications.Any())
        {
            <div class="alert alert-info">You have not applied for any elections yet.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Election</th>
                            <th>Slogan</th>
                            <th>Manifesto</th>
                            <th>Photo</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var app in Model.Applications)
                        {
                            var statusClass = app.Status == "Active" ? "status-active" :
                            app.Status == "Rejected" ? "status-rejected" : "status-pending";
                            <tr>
                                <td>
                                    <a href="/Election/Details/@app.ElectionId"
                                       class="text-decoration-none fw-bold text-dark">
                                        @app.ElectionTitle
                                    </a>
                                </td>
                                <td>@app.Slogan</td>
                                <td>@app.Manifesto</td>
                                <td>
                                    <img src="@app.Photo" alt="Candidate Photo" class="photo-preview" />
                                </td>
                                <td>
                                    <span class="status-badge @statusClass">@app.Status</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
