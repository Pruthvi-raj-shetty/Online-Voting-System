@page
@model VotingSystem.Pages.CandidateRequestModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Candidate Requests</title>
    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            display: flex;
            height: 100vh;
            background-color: #ecf0f1;
        }

        .sidebar {
            width: 250px;
            background-color: #2c3e50;
            color: white;
            display: flex;
            flex-direction: column;
            padding-top: 20px;
        }

            .sidebar h2 {
                text-align: center;
                margin-bottom: 30px;
                font-size: 22px;
            }

            .sidebar a {
                text-decoration: none;
                color: white;
                padding: 15px 20px;
                display: block;
                transition: background 0.3s;
            }

                .sidebar a:hover {
                    background-color: #34495e;
                }

            .sidebar .logout {
                margin-top: auto;
                background-color: #e74c3c;
            }

                .sidebar .logout:hover {
                    background-color: #c0392b;
                }

        .main-content {
            flex: 1;
            padding: 20px;
            overflow-y: auto;
        }

            .main-content h1 {
                color: #2c3e50;
                margin-top: 0;
            }

        .content-box {
            background: white;
            padding: 20px;
            margin-top: 20px;
            border-radius: 8px;
            box-shadow: 0px 2px 5px rgba(0,0,0,0.1);
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
        }

        th, td {
            padding: 12px;
            border-bottom: 1px solid #ddd;
            text-align: left;
        }

        th {
            background-color: #2c3e50;
            color: white;
        }

        img {
            height: 50px;
            width: 50px;
            object-fit: cover;
            border-radius: 4px;
        }

        .btn {
            padding: 6px 12px;
            border: none;
            cursor: pointer;
            border-radius: 4px;
            color: white;
            margin-right: 5px;
        }

        .btn-accept {
            background-color: #27ae60;
        }

        .btn-reject {
            background-color: #e74c3c;
        }

        .btn:hover {
            opacity: 0.85;
        }
    </style>
</head>
<body>
    <div class="sidebar">
        <h2>Admin Panel</h2>
        <a href="/CandidateRequest">Candidate Requests</a>
        <a href="/ElectionManagement">Election Management</a>
        <a href="#">Results</a>
        <a href="/login" class="logout">Logout</a>
    </div>

    <div class="main-content">
        <h1>Pending Candidate Requests</h1>
        <div class="content-box">
            @if (Model.Requests == null || Model.Requests.Count == 0)
            {
                <p>No pending requests found.</p>
            }
            else
            {
                <table>
                    <thead>
                        <tr>
                            <th>Photo</th>
                            <th>Name</th>
                            <th>Election</th>
                            <th>Slogan</th>
                            <th>Manifesto</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var req in Model.Requests)
                        {
                            <tr>
                                <td>
                                    <img src="@req.Photo" alt="Candidate Photo" />
                                </td>
                                <td>@req.UserName</td>
                                <td>@req.ElectionTitle</td>
                                <td>@req.Slogan</td>
                                <td>@req.Manifesto</td>
                                <td>
                                    <form method="post" asp-page-handler="Accept" asp-route-id="@req.CandidateId" style="display:inline;">
                                        <button type="submit" class="btn btn-accept">Accept</button>
                                    </form>
                                    <form method="post" asp-page-handler="Reject" asp-route-id="@req.CandidateId" style="display:inline;">
                                        <button type="submit" class="btn btn-reject">Reject</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</body>
</html>
