@page
@model VotingSystem.Pages.AdminDashboardModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard</title>
    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            display: flex;
            height: 100vh;
        }

        .sidebar {
            width: 250px;
            background-color: #2c3e50;
            color: white;
            display: flex;
            flex-direction: column;
            padding-top: 20px;
        }

            .sidebar h2 {
                text-align: center;
                margin-bottom: 30px;
                font-size: 22px;
            }

            .sidebar a {
                text-decoration: none;
                color: white;
                padding: 15px 20px;
                display: block;
                transition: background 0.3s;
            }

                .sidebar a:hover {
                    background-color: #34495e;
                }

            .sidebar .logout {
                margin-top: auto;
                background-color: #e74c3c;
            }

                .sidebar .logout:hover {
                    background-color: #c0392b;
                }

        .main-content {
            flex: 1;
            background-color: #ecf0f1;
            padding: 20px;
            overflow-y: auto;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: column;
        }

        h1 {
            color: #2c3e50;
        }

        .welcome-box {
            background: white;
            padding: 40px;
            border-radius: 8px;
            box-shadow: 0px 2px 6px rgba(0,0,0,0.1);
            text-align: center;
        }

            .welcome-box h2 {
                margin: 0 0 10px;
            }

            .welcome-box p {
                color: #555;
            }
    </style>
</head>
<body>
    <div class="sidebar">
        <h2>Admin Panel</h2>
        <a href="/CandidateRequest">Candidate Requests</a>
        <a href="/ElectionManagement">Election Management</a>
        <a href="/Results">Results</a>
        <a href="/FeedbackList">User Feedback</a>
        <a href="/login" class="logout">Logout</a>
      

    </div>

    <div class="main-content">
        <div class="welcome-box">
            <h2>Welcome, Admin!</h2>
            <p>Select an option from the sidebar to manage candidates, elections, or view results.</p>
        </div>
    </div>
</body>
</html>
