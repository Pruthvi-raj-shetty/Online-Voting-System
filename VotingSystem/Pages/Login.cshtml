@page
@model VotingSystem.Pages.LoginModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <title>Login</title>
    <style>
        html, body {
            margin: 0;
            padding: 0;
            font-family: Arial, sans-serif;
            background-color: #1541d1;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            box-sizing: border-box;
        }

        .container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            width: 90%;
            max-width: 1400px; /* Increased width */
            gap: 40px;
        }

        .welcome-text {
            color: white;
            font-size: 60px; /* Bigger text */
            font-weight: bold;
        }

        .welcome-subtext {
            margin-top: 15px;
            font-size: 22px; /* Bigger subtext */
            color: #e0e0e0;
            max-width: 500px;
        }

        .login-box {
            background: #fff;
            border-radius: 12px;
            padding: 40px;
            width: 400px; /* Slightly wider login box */
            box-shadow: 0 6px 15px rgba(0, 0, 0, 0.25);
        }

            .login-box h2 {
                margin-bottom: 25px;
                font-size: 26px;
                font-weight: bold;
                text-align: center;
            }

        label {
            font-size: 15px;
            font-weight: bold;
            display: block;
            margin: 10px 0 5px;
        }

        input[type="text"], input[type="password"] {
            width: 100%;
            padding: 12px;
            margin-bottom: 20px;
            border: 1px solid #ccc;
            border-radius: 6px;
            font-size: 16px;
        }

        .btn {
            display: block;
            width: 100%;
            padding: 14px;
            background-color: #007bff;
            color: white;
            font-size: 18px;
            font-weight: bold;
            border: none;
            border-radius: 30px;
            cursor: pointer;
            transition: background-color 0.3s ease;
        }

            .btn:hover {
                background-color: #0056b3;
            }

        .register-link {
            margin-top: 20px;
            text-align: center;
        }

            .register-link a {
                color: #007bff;
                text-decoration: none;
                font-size: 15px;
            }

                .register-link a:hover {
                    text-decoration: underline;
                }
    </style>
</head>
<body>
    <div class="container">
        <!-- Left Side: Welcome -->
        <div>
            <div class="welcome-text">Welcome</div>
            <div class="welcome-subtext">Your trusted platform for secure online voting.</div>
        </div>

        <!-- Right Side: Login Box -->
        <div class="login-box">
            <h2>Sign in</h2>
            <form method="post">
                <label for="email">Email</label>
                <input type="text" id="email" name="email" placeholder="Enter your Email" />

                <label for="password">Password</label>
                <input type="password" id="password" name="password" placeholder="Enter your password" />

                <button type="submit" class="btn">Login</button>
            </form>
            <div class="register-link">
                <p>Don’t have an account? New User? <a href="/Register">Register here</a></p>
            </div>
        </div>
    </div>

    @if (TempData["LoginError"] != null)
    {
        <script>
            Swal.fire({
                icon: 'error',
                title: 'Login Failed',
                text: '@TempData["LoginError"]',
                confirmButtonColor: '#007bff',
                confirmButtonText: 'Try Again',
                scrollbarPadding: false,
                allowOutsideClick: false,
                backdrop: true,
                didOpen: () => {
                    document.body.style.paddingRight = '0px';
                }
            });
        </script>
    }
</body>
</html>
