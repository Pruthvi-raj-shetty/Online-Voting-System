@page
@model VotingSystem.Pages.FeedbackListModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Feedback</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            display: flex;
            height: 100vh;
        }

        .sidebar {
            width: 250px;
            background-color: #2c3e50;
            color: white;
            display: flex;
            flex-direction: column;
            padding-top: 20px;
        }

            .sidebar h2 {
                text-align: center;
                margin-bottom: 30px;
                font-size: 22px;
            }

            .sidebar a {
                text-decoration: none;
                color: white;
                padding: 15px 20px;
                display: block;
                transition: background 0.3s;
            }

                .sidebar a:hover {
                    background-color: #34495e;
                }

            .sidebar .logout {
                margin-top: auto;
                background-color: #e74c3c;
            }

                .sidebar .logout:hover {
                    background-color: #c0392b;
                }

        .main-content {
            flex: 1;
            background-color: #ecf0f1;
            padding: 20px;
            overflow-y: auto;
        }

        h2.page-title {
            color: #2c3e50;
            margin-bottom: 20px;
        }

        .feedback-card {
            background: white;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 2px 6px rgba(0,0,0,0.1);
            margin-bottom: 15px;
        }

            .feedback-card h5 {
                margin-bottom: 5px;
                font-weight: bold;
            }

            .feedback-card p {
                margin-bottom: 0;
                word-wrap: break-word;
            }

            .feedback-card .submitted-at {
                font-size: 0.85rem;
                color: #777;
                margin-top: 5px;
            }
    </style>
</head>
<body>
    <div class="sidebar">
        <h2>Admin Panel</h2>
        <a href="/CandidateRequest">Candidate Requests</a>
        <a href="/ElectionManagement">Election Management</a>
        <a href="/Results">Results</a>
        <a href="/FeedbackList">User Feedback</a>
        <a href="/login" class="logout">Logout</a>
    </div>

    <div class="main-content">
        <h2 class="page-title">📝 User Feedback</h2>

        @if (Model.Feedbacks != null && Model.Feedbacks.Any())
        {
            @foreach (var f in Model.Feedbacks)
            {
                <div class="feedback-card">
                    <h5>@f.Name (@f.Email)</h5>
                    <p>@f.Message</p>
                    <div class="submitted-at">@f.SubmittedAt.ToString("dd MMM yyyy, hh:mm tt")</div>
                </div>
            }
        }
        else
        {
            <div class="alert alert-info text-center">
                No feedback submitted yet.
            </div>
        }
    </div>
</body>
</html>
